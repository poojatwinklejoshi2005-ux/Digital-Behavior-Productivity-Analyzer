    "# ================================\n",
    "# Digital Behavior & Productivity Analyzer\n",
    "# ================================\n",
    "\n",
    "# 1. Import Libraries\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 2. Create Sample Data\n",
    "data = {\n",
    "    \"Date\": [\n",
    "        \"2026-04-01\",\"2026-04-01\",\"2026-04-01\",\"2026-04-01\",\n",
    "        \"2026-04-02\",\"2026-04-02\",\"2026-04-02\",\"2026-04-02\"\n",
    "    ],\n",
    "    \n",
    "    \"App\": [\n",
    "        \"Instagram\",\"Snapchat\",\"YouTube\",\"Chrome\",\n",
    "        \"Instagram\",\"YouTube\",\"Snapchat\",\"chrome\"\n",
    "    ],\n",
    "    \n",
    "    \"Usage_Time(min)\": [120, 90, 180, 60, 100, 200, 80,127],\n",
    "    \n",
    "    \"Category\": [\n",
    "        \"Entertainment\",\"Entertainment\",\"Productive\",\"Productive\",\n",
    "        \"Entertainment\",\"Productive\",\"Entertainment\",\"Productive\"\n",
    "    ]\n",
    "}\n",
    "\n",
    "# 3. Convert to DataFrame\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "print(\"\\n Raw Data:\\n\")\n",
    "print(df)\n",
    "\n",
    "# 4. Data Cleaning\n",
    "df = df.dropna()\n",
    "df[\"Usage_Time(min)\"] = df[\"Usage_Time(min)\"].astype(int)\n",
    "\n",
    "# 5. Total Usage by Category\n",
    "total_usage = df.groupby(\"Category\")[\"Usage_Time(min)\"].sum()\n",
    "\n",
    "print(\"\\n Total Usage by Category:\\n\")\n",
    "print(total_usage)\n",
    "\n",
    "# 6. Plot Category-wise Usage\n",
    "plt.figure()\n",
    "total_usage.plot(kind=\"bar\")\n",
    "plt.title(\"Category-wise Usage\")\n",
    "plt.xlabel(\"Category\")\n",
    "plt.ylabel(\"Time (minutes)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 7. Daily Usage Trend\n",
    "daily_usage = df.groupby(\"Date\")[\"Usage_Time(min)\"].sum()\n",
    "\n",
    "print(\"\\n Daily Usage:\\n\")\n",
    "print(daily_usage)\n",
    "\n",
    "plt.figure()\n",
    "daily_usage.plot(marker=\"o\")\n",
    "plt.title(\"Daily Usage Trend\")\n",
    "plt.xlabel(\"Date\")\n",
    "plt.ylabel(\"Time (minutes)\")\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 8. Productivity Score Calculation\n",
    "productive = df[df[\"Category\"] == \"Productive\"][\"Usage_Time(min)\"].sum()\n",
    "entertainment = df[df[\"Category\"] == \"Entertainment\"][\"Usage_Time(min)\"].sum()\n",
    "\n",
    "total = productive + entertainment\n",
    "\n",
    "score = (productive / total) * 100 if total != 0 else 0\n",
    "\n",
    "print(\"\\n Productivity Score:\", round(score, 2), \"%\")\n",
    "\n",
    "# 9. Insights\n",
    "print(\"\\n Insight:\")\n",
    "if score > 70:\n",
    "    print(\"Excellent productivity! \")\n",
    "elif score > 50:\n",
    "    print(\"Good, but can improve \")\n",
    "else:\n",
    "    print(\"Too much distraction! \")\n",
    "\n",
    "# 10. Top Apps Usage\n",
    "top_apps = df.groupby(\"App\")[\"Usage_Time(min)\"].sum().sort_values(ascending=False)\n",
    "\n",
    "print(\"\\n Top Apps:\\n\")\n",
    "print(top_apps)\n",
    "\n",
    "# 11. Pie Chart Visualization\n",
    "plt.figure()\n",
    "total_usage.plot(kind=\"pie\", autopct=\"%1.1f%%\")\n",
    "plt.title(\"Usage Distribution\")\n",
    "plt.ylabel(\"\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 12. Save Report\n",
    "file_name = \"final_report.csv\"\n",
    "df.to_csv(file_name, index=False)\n",
    "\n",
    "print(f\"\\n Report saved as '{file_name}'\")\n",
    "\n",
    "# 13. Show File Location\n",
    "import os\n",
    "print(\" File saved at:\", os.path.abspath(file_name))"
   ]
